---
import '../../styles/global.css';
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <title>Vibify — Signing in…</title>
    </head>
    <body class="flex min-h-screen items-center justify-center">
        <p id="status" class="text-muted">Completing login…</p>
        <script>
            import { api } from '../../lib/api';
            import { $auth } from '../../stores/auth';

            const status = document.getElementById('status')!;
            const code = new URLSearchParams(location.search).get('code');
            history.replaceState({}, '', '/login/callback');

            if (!code) {
                status.textContent = 'Missing code — go back and log in again.';
            } else {
                api.exchange(code)
                    .then(({ userId, api_token }) => {
                        $auth.set({ userId, apiToken: api_token });
                        location.href = '/dashboard';
                    })
                    .catch(err => {
                        status.textContent = `Login failed: ${err.message}. Codes expire in 2 minutes — try again.`;
                    });
            }
        </script>
    </body>
</html>

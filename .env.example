# Spotify app (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID="YOUR_SPOTIFY_CLIENT_ID"
SPOTIFY_CLIENT_SECRET="YOUR_SPOTIFY_CLIENT_SECRET"
# Must exactly match a redirect URI registered in the Spotify dashboard.
# New Spotify apps only accept HTTPS or loopback (http://127.0.0.1:...) URIs.
SPOTIFY_REDIRECT_URI="http://192.168.1.89:3333/auth/callback"

# API server
HOST="0.0.0.0"
PORT=3333
# Where /auth/callback redirects after login (Astro dev server, or the API itself in prod)
FRONTEND_URL="http://192.168.1.89:5432"
# Comma-separated allowed origins (dev only; prod same-origin needs none)
CORS_ORIGIN="http://192.168.1.89:5432,http://localhost:5432"

# DEV_MODE=true skips API-key auth and uses DEV_USER_ID. Never expose such an instance.
DEV_MODE=false
DEV_USER_ID=""
# Shared secret for trusted first-party consumers (send X-Application-Id + X-User-Id headers)
APPLICATION_ID="YOUR_APPLICATION_ID"

# MySQL
DB_HOST="localhost"
DB_PORT=3306
DB_NAME=vibify
DB_USER="YOUR_DB_USER"
DB_PASS="YOUR_DB_PASS"

# Redis (required: caching, login handoff codes, sync job progress)
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379

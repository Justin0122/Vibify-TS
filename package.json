{
  "name": "vibify",
  "version": "2.0.0",
  "description": "Self-hosted Spotify companion API + web UI",
  "main": "dist/server.js",
  "author": "Justin0122",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc --project tsconfig.json && tsc-alias -p tsconfig.json",
    "createdb": "node src/db/createdb.js",
    "migrate": "knex migrate:latest --knexfile src/db/knexfile.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build"
  },
  "dependencies": {
    "@spotify/web-api-ts-sdk": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "knex": "^3.1.0",
    "mysql2": "^3.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^15.14.0",
    "prettier": "3.4.2",
    "supertest": "^7.0.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.21.0",
    "vitest": "^3.0.0"
  }
}
